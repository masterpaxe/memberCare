@page "/visitors"
@inject AppState AppState
@inject ApiClient Api

<PageTitle>Visitors – MemberCare</PageTitle>

<article>
    <div class="panel">
        <h2>Visitor / First-Timer Management</h2>
        @if (!string.IsNullOrEmpty(_error))
        {
            <p class="err-msg">@_error</p>
        }
        <EditForm Model="_form" OnValidSubmit="SubmitAsync" FormName="visitorForm">
            <div class="grid-form">
                <InputText @bind-Value="_form.FullName" placeholder="Visitor name" required />
                <InputText @bind-Value="_form.Phone" placeholder="Phone" required />
                <InputDate @bind-Value="_form.ServiceDate" />
                <InputText @bind-Value="_form.InvitedBy" placeholder="Invited by" />
                <button class="btn btn-solid" type="submit" disabled="@_submitting">
                    @(_submitting ? "Saving…" : "Add Visitor")
                </button>
            </div>
        </EditForm>
    </div>

    <div class="panel">
        <h3>Visitors Queue</h3>
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>ID</th><th>Name</th><th>Service Date</th><th>Status</th><th>Branch</th><th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_loading)
                    {
                        <tr><td colspan="6" class="loading-msg">Loading…</td></tr>
                    }
                    else if (_visitors.Count == 0)
                    {
                        <tr><td colspan="6">No visitors recorded.</td></tr>
                    }
                    else
                    {
                        @foreach (var v in _visitors)
                        {
                            var vid = v.VisitorId;
                            <tr>
                                <td>@v.VisitorId.ToString()[..8]…</td>
                                <td>@v.FirstName @v.LastName</td>
                                <td>@v.FirstAttendanceDate[..10]</td>
                                <td><span class="tag">@v.FollowUpStatus</span></td>
                                <td>@v.BranchId.ToString()[..8]…</td>
                                <td>
                                    <button class="btn btn-ghost"
                                            @onclick="() => ConvertAsync(vid)"
                                            disabled="@_converting">
                                        Convert
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</article>

@code {
    private List<VisitorDto> _visitors = [];
    private bool _loading;
    private bool _submitting;
    private bool _converting;
    private string? _error;
    private VisitorForm _form = new();

    protected override async Task OnInitializedAsync()
    {
        if (AppState.IsConnected) await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try { _visitors = await Api.GetVisitorsAsync(); }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private async Task SubmitAsync()
    {
        if (!AppState.IsConnected) { _error = "Click Apply to connect first."; return; }
        _submitting = true;
        _error = null;
        try
        {
            var parts = _form.FullName.Trim().Split(' ', 2);
            var ok = await Api.CreateVisitorAsync(new
            {
                branchId = AppState.BranchId,
                firstName = parts[0],
                lastName = parts.Length > 1 ? parts[1] : "",
                phone = _form.Phone,
                firstAttendanceDate = _form.ServiceDate.ToString("yyyy-MM-dd")
            });
            if (ok) { _form = new(); await LoadAsync(); }
            else _error = "Create failed.";
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _submitting = false; }
    }

    private async Task ConvertAsync(Guid visitorId)
    {
        _converting = true;
        _error = null;
        try
        {
            await Api.ConvertVisitorAsync(visitorId);
            await LoadAsync();
        }
        catch (Exception ex) { _error = $"Conversion failed: {ex.Message}"; }
        finally { _converting = false; }
    }

    private class VisitorForm
    {
        public string FullName { get; set; } = "";
        public string Phone { get; set; } = "";
        public DateOnly ServiceDate { get; set; } = DateOnly.FromDateTime(DateTime.Today);
        public string InvitedBy { get; set; } = "";
    }
}
